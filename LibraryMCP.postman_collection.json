{
  "info": {
    "name": "LibraryMCP API",
    "description": "Library management API with books, members, and loans.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "description": "Obtain a JWT bearer token. Submit credentials as form data (username + password). Default credentials: admin / secret (override via ADMIN_USERNAME / ADMIN_PASSWORD env vars).",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "admin",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "secret",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/auth/token",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "token"]
            }
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "List Books",
          "request": {
            "method": "GET",
            "description": "List all books with optional filters.\n\n- **title**: Filter books by title (Optional[str])\n- **author**: Filter books by author (Optional[str])\n- **genre**: Filter books by genre (Optional[str])\n- **available_only**: If True, only return books with available_copies > 0 (bool)",
            "url": {
              "raw": "{{baseUrl}}/books/",
              "host": ["{{baseUrl}}"],
              "path": ["books", ""],
              "query": [
                {
                  "key": "title",
                  "value": "",
                  "description": "Filter by book title (partial match)",
                  "disabled": true
                },
                {
                  "key": "author",
                  "value": "",
                  "description": "Filter by author name (partial match)",
                  "disabled": true
                },
                {
                  "key": "genre",
                  "value": "",
                  "description": "Filter by genre (partial match)",
                  "disabled": true
                },
                {
                  "key": "available_only",
                  "value": "false",
                  "description": "Show only books with available copies",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "description": "Add a new book to the catalog.\n\n- **book**: Book details for creation (BookCreate)\n\nReturns the created book with its assigned ID and available_copies set to total_copies.\nRaises 409 Error if a book with the same ISBN already exists.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"title\": \"1984\",\n  \"author\": \"George Orwell\",\n  \"isbn\": \"978-0451524935\",\n  \"total_copies\": 1,\n  \"genre\": \"Fiction\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/books/",
              "host": ["{{baseUrl}}"],
              "path": ["books", ""]
            }
          }
        },
        {
          "name": "Get Book",
          "request": {
            "method": "GET",
            "description": "Retrieve a book by its ID.\n\n- **book_id**: The unique identifier of the book to retrieve (int)",
            "url": {
              "raw": "{{baseUrl}}/books/1",
              "host": ["{{baseUrl}}"],
              "path": ["books", "1"]
            }
          }
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "description": "Update an existing book in the database by book_id.\n\n- **book_id**: The unique identifier of the book to update (int)\n- **book_update**: The fields to update (BookUpdate)",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"title\": null,\n  \"author\": null,\n  \"isbn\": null,\n  \"total_copies\": null,\n  \"available_copies\": null,\n  \"genre\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/books/1",
              "host": ["{{baseUrl}}"],
              "path": ["books", "1"]
            }
          }
        },
        {
          "name": "Delete Book",
          "request": {
            "method": "DELETE",
            "description": "Delete a book from the database by book_id.\n\n- **book_id**: The unique identifier of the book to delete (int)",
            "url": {
              "raw": "{{baseUrl}}/books/1",
              "host": ["{{baseUrl}}"],
              "path": ["books", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "List Members",
          "request": {
            "method": "GET",
            "description": "List all members with optional filters\n\n- **skip**: Number of records to skip for pagination\n- **limit**: Maximum number of records to return (1-500)\n- **name**: Filter by member name (case-insensitive partial match)\n- **email**: Filter by email address (case-insensitive partial match)\n- **is_active**: Filter by active status (true/false)\n\nNote: This endpoint returns basic member info without loan history for performance.\nUse GET /members/{id} to get detailed information with loans and fines.",
            "url": {
              "raw": "{{baseUrl}}/members/",
              "host": ["{{baseUrl}}"],
              "path": ["members", ""],
              "query": [
                {
                  "key": "skip",
                  "value": "0",
                  "description": "Number of records to skip (pagination)",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "100",
                  "description": "Max records to return (1-500)",
                  "disabled": true
                },
                {
                  "key": "name",
                  "value": "",
                  "description": "Filter by name (partial match)",
                  "disabled": true
                },
                {
                  "key": "email",
                  "value": "",
                  "description": "Filter by email (partial match)",
                  "disabled": true
                },
                {
                  "key": "is_active",
                  "value": "true",
                  "description": "Filter by active status",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Register Member",
          "request": {
            "method": "POST",
            "description": "Creates a new member\n\n- **name**: The name of the member.\n- **email**: The email address of the member (must be valid format).\n- **joined_date**: The date the member joined. Defaults to today's date.\n- **is_active**: Whether the member is active. Defaults to True.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"name\": \"Bob Smith\",\n  \"email\": \"bob@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/members/",
              "host": ["{{baseUrl}}"],
              "path": ["members", ""]
            }
          }
        },
        {
          "name": "Get Member",
          "request": {
            "method": "GET",
            "description": "Returns a member by ID with complete loan history and fines\n\n- **member_id**: The unique identifier of the member to retrieve.\n\nReturns:\n- Member profile\n- All loans (active and historical)\n- Active loans count\n- Total outstanding fines",
            "url": {
              "raw": "{{baseUrl}}/members/1",
              "host": ["{{baseUrl}}"],
              "path": ["members", "1"]
            }
          }
        },
        {
          "name": "Update Member",
          "request": {
            "method": "PUT",
            "description": "Update member information\n\n- **member_id**: The unique identifier of the member to update.\n- **name**: New name (optional)\n- **email**: New email (optional, must be valid and unique)\n- **is_active**: New active status (optional)\n\nBusiness rules:\n- Cannot deactivate member with active loans\n- Email must be unique if changed",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"name\": null,\n  \"email\": null,\n  \"is_active\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/members/1",
              "host": ["{{baseUrl}}"],
              "path": ["members", "1"]
            }
          }
        },
        {
          "name": "Delete Member",
          "request": {
            "method": "DELETE",
            "description": "Deletes a member by ID\n\n- **member_id**: The unique identifier of the member to delete.\n\nBusiness rules:\n- Cannot delete member with active loans\n- Cannot delete member with unpaid fines",
            "url": {
              "raw": "{{baseUrl}}/members/1",
              "host": ["{{baseUrl}}"],
              "path": ["members", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Loans",
      "item": [
        {
          "name": "Borrow Book",
          "request": {
            "method": "POST",
            "description": "Borrow a book (creates a loan record).\n\n- **book_id**: The ID of the book to borrow\n- **member_id**: The ID of the member borrowing the book\n\nBusiness rules:\n- Book must exist and have available copies > 0\n- Member must exist and be active\n- Member cannot borrow the same book twice simultaneously",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"book_id\": 1,\n  \"member_id\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/loans/borrow",
              "host": ["{{baseUrl}}"],
              "path": ["loans", "borrow"]
            }
          }
        },
        {
          "name": "Return Book",
          "request": {
            "method": "POST",
            "description": "Return a borrowed book.\n\n- **book_id**: The ID of the book being returned\n- **member_id**: The ID of the member returning the book\n\nBusiness rules:\n- Loan must exist and be active (not already returned)\n- Fine is calculated if book is overdue ($0.50 per day)\n- Book's available_copies is incremented",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"book_id\": 1,\n  \"member_id\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/loans/return",
              "host": ["{{baseUrl}}"],
              "path": ["loans", "return"]
            }
          }
        },
        {
          "name": "Get Active Loans",
          "request": {
            "method": "GET",
            "description": "Get all active loans for a member.\n\n- **member_id**: The ID of the member\n\nReturns only loans where returned_date is NULL (active loans).",
            "url": {
              "raw": "{{baseUrl}}/loans/1",
              "host": ["{{baseUrl}}"],
              "path": ["loans", "1"]
            }
          }
        },
        {
          "name": "Check Fines",
          "request": {
            "method": "GET",
            "description": "Calculate overdue fines for a member.\n\n- **member_id**: The ID of the member\n\nReturns:\n- **member_id**: The member's ID\n- **total_fines**: Total outstanding fines (includes overdue active loans and unpaid fines from returned books)\n- **active_overdue_loans**: Number of currently overdue active loans\n- **unpaid_returned_fines**: Total fines from returned books that haven't been paid\n\nFine calculation:\n- $0.50 per day overdue for active loans\n- Includes fine_amount from returned books (if not paid)",
            "url": {
              "raw": "{{baseUrl}}/loans/1/fines",
              "host": ["{{baseUrl}}"],
              "path": ["loans", "1", "fines"]
            }
          }
        }
      ]
    }
  ]
}
